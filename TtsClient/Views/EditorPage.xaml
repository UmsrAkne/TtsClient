<UserControl
    x:Class="TtsClient.Views.EditorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ttsEngine="clr-namespace:TtsClient.TtsEngine"
    xmlns:viewModels="clr-namespace:TtsClient.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:EditorPageViewModel}"
    d:DesignHeight="280"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource CommonFontSize}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="{StaticResource CommonFontSize}" />
            <Setter Property="Background" Value="{StaticResource TextBoxBackground}" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <TextBlock Margin="10,0" Text="Service:" />
            <ComboBox
                Width="300"
                ItemsSource="{Binding TtsService.AvailableEngines}"
                SelectedItem="{Binding TtsService.CurrentEngine}">
                <ComboBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type ttsEngine:ITtsEngine}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="{StaticResource CommonFontSize}" Text="{Binding EngineName}" />
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>

        <TextBox Grid.Row="1" Text="{Binding PendingRequest.Text, UpdateSourceTrigger=PropertyChanged, Delay=500}" />

        <Border Grid.Row="2">
            <StackPanel>

                <TextBlock Text="Control Panel" />
                <Button
                    Padding="3"
                    HorizontalAlignment="Right"
                    Command="{Binding SendRequestCommand}">
                    <Button.Content>
                        <TextBlock
                            Width="200"
                            Text="Send Request"
                            TextAlignment="Center" />
                    </Button.Content>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>