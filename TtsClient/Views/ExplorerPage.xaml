<UserControl
    x:Class="TtsClient.Views.ExplorerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:TtsClient.Models"
    xmlns:viewModels="clr-namespace:TtsClient.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:ExplorerPageViewModel}"
    d:DesignHeight="720"
    d:DesignWidth="1200"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource CommonFontSize}" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.5*" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <ListBox
            Grid.Row="0"
            Grid.RowSpan="2"
            Grid.Column="0"
            ItemsSource="{Binding SpeechEntries}">

            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:SpeechEntry}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding AudioPath}" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="0" Grid.Column="1">
            <TextBlock Text="Detail Area" />
        </Border>
    </Grid>
</UserControl>