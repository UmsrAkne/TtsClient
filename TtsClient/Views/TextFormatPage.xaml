<UserControl
    x:Class="TtsClient.Views.TextFormatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TtsClient.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:texts="clr-namespace:TtsClient.Texts"
    xmlns:viewModels="clr-namespace:TtsClient.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:TextFormatPageViewModel}"
    d:DesignHeight="400"
    d:DesignWidth="300"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource CommonFontSize}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="{StaticResource CommonFontSize}" />
            <Setter Property="Background" Value="{StaticResource TextBoxBackground}" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="1">
            <StackPanel>

                <ItemsControl ItemsSource="{Binding TextProcessingSteps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type texts:TextProcessingStep}">
                            <StackPanel>
                                <StackPanel Margin="3" Orientation="Horizontal">
                                    <CheckBox
                                        Margin="5,0"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding IsSingleLine}" />
                                    <TextBlock FontSize="{StaticResource CommonFontSize}" Text="Dot matches all (SingleLine)" />
                                </StackPanel>

                                <DockPanel LastChildFill="True">
                                    <Button
                                        Margin="5,0,0,0"
                                        Padding="2"
                                        HorizontalAlignment="Right"
                                        Command="{Binding DataContext.RemoveStepCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        DockPanel.Dock="Right">
                                        <TextBlock FontSize="{StaticResource CommonFontSize}" Text="Delete" />
                                    </Button>
                                    <TextBlock
                                        Width="80"
                                        FontSize="{StaticResource CommonFontSize}"
                                        Text="Caption :" />
                                    <TextBox FontSize="{StaticResource CommonFontSize}" Text="{Binding ExtractionPattern}" />
                                </DockPanel>

                                <ItemsControl ItemsSource="{Binding ReplacementRules}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type texts:ReplacementRule}">

                                            <DataTemplate.Resources>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontSize" Value="{StaticResource CommonFontSize}" />
                                                </Style>

                                                <Style TargetType="TextBox">
                                                    <Setter Property="FontSize" Value="{StaticResource CommonFontSize}" />
                                                    <Setter Property="Background" Value="{StaticResource TextBoxBackground}" />
                                                    <Setter Property="Margin" Value="5,0" />
                                                    <Setter Property="Width" Value="150" />
                                                </Style>
                                            </DataTemplate.Resources>

                                            <StackPanel Margin="25,2" Orientation="Horizontal">
                                                <DockPanel Margin="2">
                                                    <TextBlock Text="Pattern:" />
                                                    <TextBox Text="{Binding Pattern}" />
                                                </DockPanel>

                                                <Border Width="40" />

                                                <DockPanel Margin="2">
                                                    <TextBlock Text="Replacement:" />
                                                    <TextBox Text="{Binding Replacement}" />
                                                </DockPanel>

                                                <Button
                                                    Margin="10,0,0,0"
                                                    Padding="2"
                                                    HorizontalAlignment="Left"
                                                    Command="{Binding DataContext.RemoveReplacementRuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                    <TextBlock FontSize="{StaticResource CommonFontSize}" Text="Delete" />
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button
                                    Width="200"
                                    Margin="25,0"
                                    Padding="2"
                                    HorizontalAlignment="Left"
                                    Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=ItemsControl}, Path=DataContext.AddReplacementRuleCommand}"
                                    CommandParameter="{Binding}">
                                    <Button.Content>
                                        <TextBlock FontSize="{StaticResource CommonFontSize}" Text="Add replacement" />
                                    </Button.Content>
                                </Button>

                                <Border
                                    Height="1.5"
                                    Margin="0,5,0,0"
                                    Background="{StaticResource CommonBorderBrush}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Margin" Value="4" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                </ItemsControl>

                <Button
                    Width="200"
                    Margin="4"
                    Padding="2"
                    HorizontalAlignment="Left"
                    Command="{Binding AddStepCommand}">
                    <Button.Content>
                        <TextBlock Text="Add item" />
                    </Button.Content>
                </Button>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Margin="5">
            <Button
                Padding="30,0"
                HorizontalAlignment="Right"
                Command="{Binding StartTextProcessCommand}">
                <Button.Content>
                    <TextBlock Text="Start text process" />
                </Button.Content>
            </Button>
        </Border>

        <UniformGrid Grid.Row="3" Columns="2">

            <TextBox AcceptsReturn="True" Text="{Binding OriginalText, UpdateSourceTrigger=PropertyChanged, Delay=500}" />

            <TextBlock Margin="5" Text="{Binding ProcessedText}" />
        </UniformGrid>

        <Button
            Grid.Row="4"
            HorizontalAlignment="Right"
            Command="{Binding CopyToEditorPanelCommand}">
            <Button.Content>
                <TextBlock Padding="20,0" Text="Send to editor" />
            </Button.Content>
        </Button>
    </Grid>

</UserControl>