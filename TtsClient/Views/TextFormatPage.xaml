<UserControl
    x:Class="TtsClient.Views.TextFormatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TtsClient.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:texts="clr-namespace:TtsClient.Texts"
    xmlns:viewModels="clr-namespace:TtsClient.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:TextFormatPageViewModel}"
    d:DesignHeight="400"
    d:DesignWidth="300"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource CommonFontSize}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="{StaticResource CommonFontSize}" />
            <Setter Property="Background" Value="{StaticResource TextBoxBackground}" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="1">

            <ItemsControl ItemsSource="{Binding TextProcessingSteps}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type texts:TextProcessingStep}">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock
                                    Width="80"
                                    FontSize="{StaticResource CommonFontSize}"
                                    Text="Caption :" />
                                <TextBox FontSize="{StaticResource CommonFontSize}" Text="{Binding ExtractionPattern}" />
                            </DockPanel>

                            <ItemsControl ItemsSource="{Binding ReplacementRules}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type texts:ReplacementRule}">

                                        <DataTemplate.Resources>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontSize" Value="{StaticResource CommonFontSize}" />
                                            </Style>

                                            <Style TargetType="TextBox">
                                                <Setter Property="FontSize" Value="{StaticResource CommonFontSize}" />
                                                <Setter Property="Background" Value="{StaticResource TextBoxBackground}" />
                                                <Setter Property="Margin" Value="5,0" />
                                                <Setter Property="Width" Value="150" />
                                            </Style>
                                        </DataTemplate.Resources>

                                        <StackPanel Margin="25,2" Orientation="Horizontal">
                                            <DockPanel Margin="2">
                                                <TextBlock Text="Pattern:" />
                                                <TextBox Text="{Binding Pattern}" />
                                            </DockPanel>

                                            <Border Width="40" />

                                            <DockPanel Margin="2">
                                                <TextBlock Text="Replacement:" />
                                                <TextBox Text="{Binding Replacement}" />
                                            </DockPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border
                                Height="1.5"
                                Margin="0,5,0,0"
                                Background="{StaticResource CommonBorderBrush}" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>

                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Margin" Value="4" />
                    </Style>
                </ItemsControl.ItemContainerStyle>
            </ItemsControl>
        </ScrollViewer>

        <TextBox Grid.Row="2" Text="{Binding OriginalText, UpdateSourceTrigger=PropertyChanged, Delay=500}" />
    </Grid>

</UserControl>